<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Version>15.11</Version>
    <LangVersion>preview</LangVersion>
    <Author>croizat</Author>
    <Name>Glamour Log</Name>
    <InternalName>GlamourLog</InternalName>
    <Punchline>Gotta collect 'em all</Punchline>
    <Description>A log for all your glamours and other glam-related tweaks</Description>
    <RepoUrl>https://github.com/Jaksuhn/ffxiv_glamourlog</RepoUrl>
    <Tags>glamour</Tags>

	  <LocalCS>true</LocalCS>
  </PropertyGroup>
  <ItemGroup>
    <None Include="DalamudPackager.targets" />
  </ItemGroup>

    <PropertyGroup Condition="'$(LocalCS)'=='true'">
	    <DefineConstants>LOCAL_CS</DefineConstants>
	    <Use_Dalamud_FFXIVClientStructs>false</Use_Dalamud_FFXIVClientStructs>
    </PropertyGroup>

    <ItemGroup Condition="'$(LocalCS)'=='true'">
	    <ProjectReference Include="..\..\..\FFXIVClientStructs\FFXIVClientStructs\FFXIVClientStructs.csproj" Private="true" />
	    <ProjectReference Include="..\..\..\FFXIVClientStructs\InteropGenerator.Runtime\InteropGenerator.Runtime.csproj" Private="true" />
	    <ProjectReference Include="..\..\..\FFXIVClientStructs\InteropGenerator\InteropGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>

  <ItemGroup>
    <PackageReference Include="croizat.clib" Version="1.0.23" />
    <PackageReference Include="KamiToolKit" Version="1.1.18" />
  </ItemGroup>
</Project>
